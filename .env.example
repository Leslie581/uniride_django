# ===========================================
# DJANGO
# ===========================================
DEBUG=True
SECRET_KEY=tu_clave_secreta_aqui
ALLOWED_HOSTS=127.0.0.1,localhost

# ===========================================
# BASE DE DATOS (MYSQL DOCKER)
# ===========================================
DB_ENGINE=django.db.backends.mysql
MYSQL_DATABASE=uniride_db
MYSQL_USER=uniride_user
MYSQL_PASSWORD=uniride_pass

# MySQL en Docker NO permite root sin contraseña por defecto
MYSQL_ROOT_PASSWORD=root_password

# Datos de conexión para Django
DB_HOST=db
DB_PORT=3306

# ===========================================
# CONFIGURACIÓN REGIONAL Y LOGS
# ===========================================
TIME_ZONE=America/Mexico_City
LANGUAGE_CODE=es-mx
LOG_LEVEL=INFO